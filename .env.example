# Configuración de Entorno
# Copia este archivo a .env.local y actualiza los valores para tu entorno local

# API Configuration
REACT_APP_API_BASE_URL=https://api.petcare.dev
REACT_APP_API_TIMEOUT=10000

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_CRASHLYTICS=false

# Logging
REACT_APP_LOG_LEVEL=debug

# Versión de la app (actualizar según sea necesario)
REACT_APP_VERSION=0.0.1
